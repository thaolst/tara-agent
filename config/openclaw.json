{
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "123456:ABC-def_ghi",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "disabled"
    }
  },
  "agents": {
    "list": [
      {
        "id": "social",
        "name": "Tara Social Agent",
        "workspace": "~/.openclaw/workspace-social",
        "identity": {
          "emoji": "📢"
        },
        "subagents": {
          "allowAgents": []
        }
      }
    ]
  },
  "bindings": [
    {
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "dm",
          "id": "*"
        }
      },
      "agentId": "social"
    }
  ]
}
